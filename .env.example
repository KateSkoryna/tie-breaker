# === Gemini AI Configuration ===
# GEMINI_API_KEY is used for AI Studio preview environment automatically.
# VITE_GEMINI_API_KEY is used for local development and GitHub Actions.
# Get your key at: https://aistudio.google.com/app/apikey (Google AI Studio)
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# === Firebase Configuration ===
# These are found in Firebase Console -> Project Settings -> General -> Web App
# Note: VITE_ prefix is REQUIRED for these to be visible in the client-side code in browser.
# They are public keys and safe to be in the browser, but restricted by domain in Firebase console.
VITE_FIREBASE_API_KEY="YOUR_FIREBASE_WEB_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-messaging-id"
VITE_FIREBASE_APP_ID="your-app-id"
VITE_FIREBASE_FIRESTORE_DATABASE_ID="(default)"

# === App Configuration ===
# AI Studio automatically injects this at runtime.
APP_URL="https://your-app-url.run.app"
